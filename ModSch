const TL_START = new Date(2026, 3, 8);  // 8 Apr
const TL_END   = new Date(2026, 6, 16); // 16 Jul
const TL_TOTAL = (TL_END - TL_START) / 86400000;

function tlPct(dt) {
  return Math.max(0, Math.min(100, (dt - TL_START) / 86400000 / TL_TOTAL * 100));
}
function tlPctD(y,m,day) { return tlPct(new Date(y,m-1,day)); }

