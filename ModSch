function showContent(planId) {
  document.querySelectorAll('#cp-plan-tabs .tab').forEach((t,i) => {
    t.classList.toggle('active', ['A','B','C','X','W'][i] === planId);
  });
  renderTimeline('tl-content', planId);

  const rows = CP_PLANS[planId];
  const tbody = document.getElementById('cp-body');
  tbody.innerHTML = '';
  const sessionMap = {};
  SESSIONS.forEach(s => { sessionMap[s.id] = s; });

  let lastBlock = null;
  let sessionCounter = 0;

  rows.forEach(row => {
    const s = row.session ? sessionMap[row.session] : null;

    // Block header
    if (s && s.block !== lastBlock) {
      lastBlock = s.block;
      const tr = document.createElement('tr');
      tr.className = 'cp-month';
      tr.innerHTML = `<td colspan="8" style="background:${BLOCK_COLOURS[s.block]||'var(--bg)'}">${s.block}</td>`;
      tbody.appendChild(tr);
    }

    const tr = document.createElement('tr');

    // Row class
    const cls = row.type === 'fw'       ? 'cp-fw'
               : row.type === 'slovakia' ? 'cp-slovakia'
               : row.type === 'sa_opp'  ? 'cp-sa-opp'
               : row.type === 'sa'      ? 'cp-sa'
               : row.type === 'skip'    ? 'cp-skip'
               : 'cp-you';
    tr.className = cls;

    if (!s) {
      // Non-teaching row
      const statusLabel = row.type === 'sa_opp'   ? 'SA covers'
                        : row.type === 'fw'        ? 'Fieldwork'
                        : row.type === 'slovakia'  ? 'Slovakia fieldtrip'
                        : 'Skipped';
      tr.innerHTML = `
        <td><strong>${row.date}</strong></td>
        <td style="color:var(--empty);font-size:0.62rem">${row.day}</td>
        <td style="color:var(--empty);font-size:0.62rem">—</td>
        <td style="color:var(--empty);font-size:0.62rem;font-style:italic">${row.note||statusLabel}</td>
        <td><span class="pill ${row.type==='sa_opp'?'p-sa-opp':row.type==='fw'?'p-fw':row.type==='slovakia'?'p-slovakia':'p-empty'}">${statusLabel}</span></td>
        ${twCell(row.date)}
        <td colspan="3" style="color:var(--empty);font-size:0.62rem;font-style:italic">${row.note||''}</td>
      `;
    } else {
      if (!s.fieldwork) sessionCounter++;
      const sNum = s.fieldwork ? '' : `S${sessionCounter}`;

      // Build content list
      const contentHTML = s.content.map(c => {
        const saTag = c.sa ? `<span class="cp-sa-note"> ★ SA</span>` : '';
        const minTag = c.min ? ` ${mins(c.min)}` : '';
        return `<div class="cp-content-block">${c.text}${saTag}${minTag}</div>`;
      }).join('');

      const saHTML = s.sa
        ? `<span class="cp-sa-note">${s.sa}</span>`
        : `<span style="color:var(--empty);font-size:0.62rem">—</span>`;

      const noteHTML = [
        row.note ? `<span class="cp-note">${row.note}</span>` : '',
        s.note   ? `<span class="cp-note">${s.note}</span>`   : '',
        s.provisional ? `<span class="cp-note" style="color:#b45309">⚠ Provisional — may be fieldwork</span>` : '',
      ].filter(Boolean).join('<br>');

      const statusPill = row.type === 'sa_opp' ? '<span class="pill p-sa-opp">SA covers</span>'
                       : row.type === 'sa'      ? '<span class="pill p-sa">SA handover</span>'
                       : '<span class="pill p-you">You</span>';

      tr.innerHTML = `
        <td><strong>${row.date}</strong></td>
        <td style="color:var(--empty);font-size:0.62rem">${row.day}</td>
        <td style="font-size:0.65rem;font-weight:500">${sNum}</td>
        <td style="font-weight:500">${s.topic}</td>
        <td>${statusPill}</td>
        ${twCell(row.date)}
        <td>${contentHTML}</td>
        <td>${saHTML}</td>
        <td>${noteHTML}</td>
      `;
    }
    tbody.appendChild(tr);
  });
}

