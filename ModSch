    if (m !== lastMonth) {
      lastMonth = m;
      html += `<div class="twc-month-label">${MNL[m]} ${cur.getFullYear()}</div>`;
    }

    html += `<div class="twc-row${isWeekend?' twc-weekend':''}">`;

    // Date column
    html += `<div class="twc-date">
      <div class="twc-daynum${isWeekend?' twc-weekend-num':''}">${dNum}</div>
      <div class="twc-dayname">${DNS[dow]}</div>
    </div>`;

    // Single colour block — determined by which window(s) this date falls in
    // Priority: long window > short window > none; show all applicable options as stacked swatches
    html += `<div style="display:flex;align-items:center;gap:4px;flex:1;padding:6px 0;">`;
    let anyWindow = false;
    TWC_TRIPS.forEach(t => {
      const inLong  = cur >= t.long.s  && cur <= t.long.e;
      const inShort = cur >= t.short.s && cur <= t.short.e;
      if (inLong || inShort) {
        anyWindow = true;
        const bg = inLong ? t.color : t.colorLight;
        const border = inShort && !inLong ? `border:1.5px solid ${t.color};` : '';
        const tooltip = inLong && inShort ? `${t.label}: short + long window`
                      : inLong            ? `${t.label}: long window only`
                      :                     `${t.label}: short window only`;
        html += `<div style="height:28px;flex:1;border-radius:3px;background:${bg};${border}" title="${tooltip}"></div>`;
      } else {
        html += `<div style="height:28px;flex:1;border-radius:3px;background:#e8e3d8;opacity:0.25;" title="No ${t.label} window"></div>`;
      }
    });
    html += `</div>`;

    // Markers column
    html += `<div class="twc-markers">`;
    const fixed = TWC_FIXED[dateKey];
    if (fixed) html += `<span class="twc-tag ${fixed.tag}">${fixed.label}</span>`;
    html += `</div>`; // twc-markers

    html += `</div>`; // twc-row
    cur = addDays(cur, 1);
  }

  html += `</div>`; // twc-wrap
  container.innerHTML = html;
}

// ══ TRAVEL CALENDAR TAB ══
const TC_WINDOWS = {
  'a-short': { s: new Date(2026,3,10), e: new Date(2026,3,17) },
  'a-long':  { s: new Date(2026,3,10), e: new Date(2026,3,19) },
  'b-short': { s: new Date(2026,3,24), e: new Date(2026,4,1)  },
  'b-long':  { s: new Date(2026,3,24), e: new Date(2026,4,3)  },
  'c-short': { s: new Date(2026,4,8),  e: new Date(2026,4,15) },
  'c-long':  { s: new Date(2026,4,8),  e: new Date(2026,4,17) },
};
const TC_CONSTRAINTS = {
  '2026-4-21': 'Citizenship appointment (Ausländerbehörde)',
  '2026-5-5':  'German exam',
  '2026-5-6':  'Citizenship exam',
  '2026-5-14': 'National holiday',
};
const TC_HOLIDAY = '2026-5-14';
const TC_OPTS = ['a-short','a-long','b-short','b-long','c-short','c-long'];
const TC_MONTHS_LONG = ['January','February','March','April','May','June','July'];
const TC_DAYS_SHORT  = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

let tcRendered = false;
function renderTravelCal() {
  if (tcRendered) return;
  tcRendered = true;
  const tbody = document.getElementById('tc-cal-body');
  let cur = new Date(2026, 3, 8);
  const end = new Date(2026, 4, 31);
  let lastMonth = -1;

  while (cur <= end) {
    const m = cur.getMonth();
    const dNum = cur.getDate();
    const dow = cur.getDay();
    const isWeekend = dow === 0 || dow === 6;
    const ck = `${cur.getFullYear()}-${m+1}-${dNum}`;
    const constraint = TC_CONSTRAINTS[ck];

    if (m !== lastMonth) {
      lastMonth = m;
      const sep = document.createElement('tr');
      sep.className = 'tc-month-sep';
      sep.innerHTML = `<td colspan="8">${TC_MONTHS_LONG[m]} 2026</td>`;
      tbody.appendChild(sep);
    }

    const tr = document.createElement('tr');
    if (ck === TC_HOLIDAY)  tr.className = isWeekend ? 'tc-weekend tc-holiday-row'    : 'tc-holiday-row';
    else if (constraint)    tr.className = isWeekend ? 'tc-weekend tc-constraint-row' : 'tc-constraint-row';
    else if (isWeekend)     tr.className = 'tc-weekend';

    const dateTd = `<td class="tc-col-date">
      <span class="tc-date-num">${dNum}</span>
      <span class="tc-date-day">${TC_DAYS_SHORT[dow]}</span>
    </td>`;

    const optCells = TC_OPTS.map(key => {
      const away = cur >= TC_WINDOWS[key].s && cur <= TC_WINDOWS[key].e;
      return `<td class="${away ? 'tc-away-'+key : ''}">${away ? '✈' : ''}</td>`;
    }).join('');

    const labelTd = `<td class="tc-constraint-label">${constraint || ''}</td>`;

    tr.innerHTML = dateTd + optCells + labelTd;
    tbody.appendChild(tr);
    cur = addDays(cur, 1);
  }
}

