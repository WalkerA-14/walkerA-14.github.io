  });

  const preDays = BASE.filter(r => {
    if (r[0]==='_MONTH') return false;
    const ov=plan[r[0]]; const t=(ov&&!r[2])?ov[0]:r[2];
    return ['you','sa','sa_opp'].includes(t) && !r[0].includes('Jun') && !r[0].includes('Jul');
  }).length;
  const preH=preDays*4, total=preH+20;
  const youH=youD*4, saH=(saD+saOppD)*4;
  document.getElementById('stats').innerHTML=`
    <div class="stat-item"><strong>${preDays*2}</strong><span class="stat-label">Pre-fw slots</span></div>
    <div class="stat-item"><strong>${preH}</strong><span class="stat-label">Pre-fw hrs / SWS</span></div>
