    // post: if plan overrides to a teaching type, fall through to teaching renderer
    if (type==='post') {
      addRow(tbody,'r-post',`${td(`<strong>${date}</strong>`)}${td(day,'sid')}${td(pill(type))}${twCell(date)}${td('To be planned after fieldwork week','nt')}${td('','tlbl')}${td('','nt')}${td('—','tc')}${td('—','tc')}`);
      return;
    }
    if (!isTeach) {
      addRow(tbody,'r-single',`${td(`<strong>${date}</strong>`)}${td(day,'sid')}${td(pill(type))}${twCell(date)}${td('—','sid')}${td('—','tlbl')}${td(note||'','nt')}${td('—','tc')}${td('—','tc')}`);
      return;
    }

    dayN++;
    if (type==='you') youD++;
    else if (type==='sa') saD++;
    else saOppD++;
    hrs+=4; sws+=4;
    const hA=hrs-2, hB=hrs, sA=sws-2, sB=sws;
    const hitA=hA===60, hitB=hB===60;

    const twC = twCell(date);
    addRow(tbody,'r-a'+rowCls,`${td(`<strong>${date}</strong>`)}${td(day,'sid')}${td(pill(type))}${twC}${td(`Session ${dayN}a &nbsp;<span style="opacity:0.55;font-size:0.6rem">2 SWS</span>`,'sid')}${td('10:15–11:45','tlbl')}${td(note||'','nt')}${td(hA+' hrs','tc'+(hitA?' hit':''))}${td(sA+' SWS','tc'+(hitA?' hit':''))}`);
    addRow(tbody,'r-brk'+rowCls,`${td('')}${td('')}${td('')}<td class="tw-cell"></td>${td('— break —','nt')}${td('11:45–12:15','tlbl')}${td('')}${td('')}${td('')}`);
