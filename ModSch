};

function twCell(dateStr) {
  // Parse date string like "Wed 8 Apr" or "Thu 30 Apr" or "Wed 6 May" etc.
  const months = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  const parts = dateStr.trim().split(' ');
  if (parts.length < 3) return `<td class="tw-cell"></td>`;
  const dayNum = parseInt(parts[parts.length-2]);
  const mon = months[parts[parts.length-1]];
  if (isNaN(dayNum) || mon === undefined) return `<td class="tw-cell"></td>`;
  const dt = new Date(2026, mon, dayNum);
  return twCellFromDate(dt);
}

function twCellFromDate(dt) {
  let inner = '';
  let hasAny = false;
  ['A','B','C'].forEach(opt => {
    const w = TW_WINDOWS[opt];
    const inLong  = dt >= w.long.s  && dt <= w.long.e;
    const inShort = dt >= w.short.s && dt <= w.short.e;
    const col = TW_COLOURS[opt];
    if (inLong) {
      hasAny = true;
      inner += `<div class="tw-pip" style="background:${col};opacity:${inShort?'1':'0.45'};" title="Option ${opt} ${inShort?'short+long':'long only'}"></div>`;
      inner += `<div class="tw-pip" style="background:${col};opacity:${inShort?'0.6':'0.15'};" title="Option ${opt} short"></div>`;
    } else {
      inner += `<div class="tw-gap"></div><div class="tw-gap"></div>`;
    }
  });
  return `<td class="tw-cell">${inner}</td>`;
}
