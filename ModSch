    slovakia: ['Slovakia fieldtrip',    'p-slovakia'],
    post:     ['Post-fieldwork TBC',    'p-empty'],
    skip:     ['Not teaching',          'p-empty'],
  };
  const [lbl,pc] = map[type] || ['—','p-empty'];
  return `<span class="pill ${pc}">${lbl}</span>`;
}

