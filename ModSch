function renderTimeline(containerId, activePlanId) {
  const container = document.getElementById(containerId);
  if (!container) return;

  // Determine which trips are highlighted
  const planBase = activePlanId ? activePlanId.replace(/-short|-long/,'') : null;

  let html = `<div class="tl-title">Semester timeline · 8 Apr – 16 Jul 2026</div>`;
  html += `<div class="tl-outer">`;

  // Month label row
  html += `<div style="position:relative;height:18px;margin-left:100px;">`;
  TL_MONTHS.forEach(m => {
    const pct = tlPct(m.dt);
    if (pct < 0 || pct > 100) return;
    html += `<span style="position:absolute;left:${pct}%;font-size:0.6rem;color:var(--empty);transform:translateX(-50%);white-space:nowrap;">${m.label}</span>`;
  });
  // Add end label
  html += `<span style="position:absolute;left:100%;font-size:0.6rem;color:var(--empty);transform:translateX(-50%);white-space:nowrap;">Jul</span>`;
  html += `</div>`;

  // Base track with fixed markers
  html += `<div class="tl-row">`;
  html += `<div class="tl-row-label" style="font-size:0.58rem;">Fixed</div>`;
  html += `<div class="tl-axis" style="position:relative;height:14px;">`;
  // background track
  html += `<div style="position:absolute;top:2px;left:0;right:0;height:10px;background:#e8e3d8;border-radius:3px;"></div>`;
  // fixed markers
  TL_FIXED.forEach(f => {
    const l = tlPct(f.start);
    const r = tlPct(new Date(f.end.getTime() + 86400000)); // end is inclusive
    const w = Math.max(0.4, r - l);
    html += `<div style="position:absolute;top:2px;left:${l}%;width:${w}%;height:10px;background:${f.color};border-radius:2px;opacity:0.85;" title="${f.label}"></div>`;
  });
  // month tick lines
  TL_MONTHS.forEach(m => {
    const p = tlPct(m.dt);
    if (p > 0 && p < 100) html += `<div style="position:absolute;top:0;left:${p}%;width:1px;height:14px;background:var(--rule);opacity:0.5;"></div>`;
  });
  html += `</div></div>`;

  // Travel rows — one per trip, long then short
  TL_TRIPS.forEach(trip => {
    const isActive = planBase === trip.id || planBase === 'W';
    const alpha = isActive ? '1' : '0.25';

    // Long bar row
    html += `<div class="tl-row">`;
    html += `<div class="tl-row-label">${trip.label} long<br><span style="font-size:0.52rem;opacity:0.7;">${trip.dateL}</span></div>`;
    html += `<div class="tl-axis" style="position:relative;height:18px;">`;
    html += `<div style="position:absolute;top:4px;left:0;right:0;height:10px;background:#e8e3d8;border-radius:3px;opacity:0.3;"></div>`;
    const ll = tlPct(trip.long.s), lr = tlPct(new Date(trip.long.e.getTime()+86400000));
    html += `<div style="position:absolute;top:4px;left:${ll}%;width:${lr-ll}%;height:10px;background:${trip.color};border-radius:2px;opacity:${alpha};"></div>`;
    TL_MONTHS.forEach(m => { const p=tlPct(m.dt); if(p>0&&p<100) html+=`<div style="position:absolute;top:0;left:${p}%;width:1px;height:18px;background:var(--rule);opacity:0.3;"></div>`; });
    html += `</div></div>`;

    // Short bar row
    html += `<div class="tl-row">`;
    html += `<div class="tl-row-label" style="opacity:0.7;">${trip.label} short<br><span style="font-size:0.52rem;">${trip.dateS}</span></div>`;
    html += `<div class="tl-axis" style="position:relative;height:9px;">`;
    html += `<div style="position:absolute;top:0;left:0;right:0;height:7px;background:#e8e3d8;border-radius:3px;opacity:0.3;"></div>`;
    const sl = tlPct(trip.short.s), sr = tlPct(new Date(trip.short.e.getTime()+86400000));
    html += `<div style="position:absolute;top:0;left:${sl}%;width:${sr-sl}%;height:7px;background:${trip.color};border-radius:2px;opacity:${isActive ? '0.65' : '0.15'};"></div>`;
    TL_MONTHS.forEach(m => { const p=tlPct(m.dt); if(p>0&&p<100) html+=`<div style="position:absolute;top:0;left:${p}%;width:1px;height:9px;background:var(--rule);opacity:0.3;"></div>`; });
    html += `</div></div>`;
  });

  html += `</div>`; // tl-outer

  // Legend
  html += `<div class="tl-legend-row">`;
  TL_TRIPS.forEach(t => {
    html += `<div class="tl-legend-item"><div class="tl-legend-dot" style="background:${t.color};"></div>${t.label} <span style="color:var(--empty);font-size:0.58rem;">(long: ${t.dateL} · short: ${t.dateS})</span></div>`;
  });
  html += `<div class="tl-legend-item"><div class="tl-legend-dot" style="background:#fca5a5;"></div>National holiday</div>`;
  html += `<div class="tl-legend-item"><div class="tl-legend-dot" style="background:#c084fc;"></div>German exam (5 May)</div>`;
  html += `<div class="tl-legend-item"><div class="tl-legend-dot" style="background:#93c5fd;"></div>Fieldwork week</div>`;
  html += `<div class="tl-legend-item"><div class="tl-legend-dot" style="background:#c4b5fd;"></div>Slovakia fieldtrip (8–12 Jun)</div>`;
  html += `<div class="tl-legend-item" style="color:var(--empty);font-style:italic;">Tall bar = long trip · Short bar = short trip · Active plan highlighted</div>`;
  html += `</div>`;

  container.innerHTML = html;
}

