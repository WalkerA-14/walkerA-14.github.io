<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Module Schedule 2026</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,wght@0,300;0,600;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f0e8; --ink: #1a1a2e; --rule: #c8bfaa;
    --you: #2d6a4f; --you-bg: #d8f3dc;
    --sa: #1d4e89; --sa-bg: #dbeafe;
    --sa-opp: #0e6655; --sa-opp-bg: #c2ede5;
    --travel: #7b4f12; --travel-bg: #fef3c7;
    --room: #6b2d6b; --room-bg: #f3e8f3;
    --holiday: #8b0000; --holiday-bg: #fee2e2;
    --fieldwork: #1a5276; --fieldwork-bg: #d6eaf8;
    --slovakia: #5b21b6; --slovakia-bg: #ede9fe;
    --empty: #888; --empty-bg: #eeebe4;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--ink); font-family: 'DM Mono', monospace; padding: 2rem; min-height: 100vh; }

  header { margin-bottom: 1.5rem; border-bottom: 2px solid var(--ink); padding-bottom: 1rem; }
  h1 { font-family: 'Fraunces', serif; font-weight: 600; font-size: 2rem; letter-spacing: -0.02em; }
  h1 span { font-style: italic; font-weight: 300; }
  .subtitle { font-size: 0.72rem; color: var(--empty); margin-top: 0.3rem; letter-spacing: 0.05em; text-transform: uppercase; }

  /* Page-level tabs */
  .page-tabs { display: flex; gap: 0; margin-bottom: 2rem; border-bottom: 2px solid var(--ink); }
  .page-tab { font-family: 'Fraunces', serif; font-style: italic; font-size: 1rem; padding: 0.5rem 1.4rem 0.4rem; border: none; background: transparent; color: var(--empty); cursor: pointer; border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.15s; }
  .page-tab:hover { color: var(--ink); }
  .page-tab.active { color: var(--ink); border-bottom: 3px solid var(--ink); }
  .page-section { display: none; }
  .page-section.visible { display: block; }

  /* Plan tabs */
  .tabs { display: flex; gap: 0.25rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .tab { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.04em; text-transform: uppercase; padding: 0.4rem 0.9rem; border: 1.5px solid var(--ink); background: transparent; color: var(--ink); cursor: pointer; transition: all 0.15s; }
  .tab:hover { background: var(--rule); }
  .tab.active { background: var(--ink); color: var(--bg); }

  /* Legend */
  .legend { display: flex; flex-wrap: wrap; gap: 0.4rem 1.1rem; margin-bottom: 1.5rem; font-size: 0.68rem; }
  .legend-item { display: flex; align-items: center; gap: 0.35rem; }
  .ldot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }

  /* Stats */
  .stats { display: flex; flex-wrap: wrap; gap: 0.8rem 1.8rem; margin-bottom: 1.8rem; padding: 0.8rem 1.1rem; background: white; border: 1.5px solid var(--rule); }
  .stat-item strong { font-size: 1.2rem; font-family: 'Fraunces', serif; display: block; line-height: 1; margin-bottom: 0.15rem; }
  .stat-label { color: var(--empty); text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.6rem; }

  /* Schedule table */
  .schedule { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
  .schedule th { text-align: left; padding: 0.45rem 0.65rem; border-bottom: 2px solid var(--ink); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; background: var(--bg); position: sticky; top: 0; white-space: nowrap; }
  .schedule td { padding: 0.3rem 0.65rem; vertical-align: middle; }
  .r-month td { font-family: 'Fraunces', serif; font-style: italic; font-size: 0.88rem; padding-top: 1.2rem; padding-bottom: 0.35rem; color: var(--empty); border-bottom: 1px solid var(--rule); }
  .r-single td { border-bottom: 1px solid var(--rule); }
  .r-a   td { border-bottom: none; padding-bottom: 0.1rem; padding-top: 0.55rem; }
  .r-brk td { border-bottom: none; padding-top: 0; padding-bottom: 0; font-size: 0.58rem; color: var(--empty); font-style: italic; opacity: 0.6; }
  .r-b   td { border-bottom: 1.5px solid var(--rule); padding-top: 0.1rem; padding-bottom: 0.5rem; }
  .opp td { background: #eaf9f5 !important; }
  .opp.r-a   td:first-child { border-left: 3px solid var(--sa-opp); }
  .opp.r-brk td:first-child { border-left: 3px solid var(--sa-opp); }
  .opp.r-b   td:first-child { border-left: 3px solid var(--sa-opp); }
  .sa-hand td { background: #eff6ff !important; }
  .sa-hand.r-a   td:first-child { border-left: 3px solid var(--sa); }
  .sa-hand.r-brk td:first-child { border-left: 3px solid var(--sa); }
  .sa-hand.r-b   td:first-child { border-left: 3px solid var(--sa); }
  .r-fw   td { background: var(--fieldwork-bg) !important; border-bottom: 1px solid #b3d4ea; }
  .r-sk   td { background: var(--slovakia-bg)  !important; border-bottom: 1px solid #c4b5fd; }
  .r-post td { opacity: 0.5; border-bottom: 1px solid var(--rule); }

  /* Pills */
  .pill { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 2px; font-size: 0.63rem; font-weight: 500; letter-spacing: 0.02em; white-space: nowrap; }
  .p-you      { background: var(--you-bg);      color: var(--you); }
  .p-sa       { background: var(--sa-bg);        color: var(--sa); }
  .p-sa-opp   { background: var(--sa-opp-bg);    color: var(--sa-opp); }
  .p-travel   { background: var(--travel-bg);    color: var(--travel); }
  .p-holiday  { background: var(--holiday-bg);   color: var(--holiday); }
  .p-room     { background: var(--room-bg);      color: var(--room); }
  .p-fw       { background: var(--fieldwork-bg); color: var(--fieldwork); }
  .p-slovakia { background: var(--slovakia-bg);  color: var(--slovakia); }
  .p-empty    { background: var(--empty-bg);     color: var(--empty); }
  .p-both     { background: #c8f0d8; color: #1a6b3c; }
  .p-col-only { background: #eddff7; color: #5c2a7a; }
  .p-you-only { background: var(--empty-bg); color: var(--empty); }
  .p-neither  { background: #f0ede6; color: #aaa; }

  .sid  { color: var(--empty); font-size: 0.62rem; }
  .tlbl { color: var(--empty); font-size: 0.62rem; font-style: italic; }
  .nt   { color: var(--empty); font-size: 0.62rem; font-style: italic; }
  .tc   { text-align: right; color: var(--empty); font-size: 0.62rem; white-space: nowrap; }
  .tc.hit { color: var(--you); font-weight: 500; }

  /* Workshop tab */
  .ws-table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
  .ws-table th { text-align: left; padding: 0.45rem 0.65rem; border-bottom: 2px solid var(--ink); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; background: var(--bg); position: sticky; top: 0; white-space: nowrap; }
  .ws-table td { padding: 0.35rem 0.65rem; border-bottom: 1px solid var(--rule); vertical-align: middle; }
  .ws-table tr:hover td { background: rgba(0,0,0,0.02); }
  .ws-month td { font-family: 'Fraunces', serif; font-style: italic; font-size: 0.88rem; padding-top: 1.2rem; padding-bottom: 0.35rem; color: var(--empty); border-bottom: 1px solid var(--rule); }
  .ws-both     td { background: #d4f5e2 !important; }
  .ws-both     td:first-child { border-left: 3px solid #1a6b3c; }
  .ws-col-only td { background: #eddff7 !important; }
  .ws-you-only td { background: var(--empty-bg) !important; opacity: 0.7; }
  .ws-neither  td { background: #f0ede6 !important; opacity: 0.45; }
  .ws-summary  { font-size: 0.68rem; color: var(--empty); margin-bottom: 1.5rem; font-style: italic; }

  /* Timeline bar */
  .tl-wrap { margin-bottom: 1.8rem; }
  .tl-title { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--empty); margin-bottom: 0.5rem; }
  .tl-outer { position: relative; width: 100%; }
  .tl-track { position: relative; height: 10px; background: #e8e3d8; border-radius: 3px; margin-bottom: 2px; overflow: visible; }
  .tl-track.tl-short { height: 7px; opacity: 0.55; }
  .tl-bar { position: absolute; top: 0; height: 100%; border-radius: 2px; }
  .tl-label-row { position: relative; height: 16px; margin-bottom: 6px; }
  .tl-month-label { position: absolute; font-size: 0.58rem; color: var(--empty); transform: translateX(-50%); white-space: nowrap; }
  .tl-tick { position: absolute; top: 0; width: 1px; height: 6px; background: var(--rule); }
  .tl-marker { position: absolute; top: -3px; width: 2px; border-radius: 1px; }
  .tl-marker-label { position: absolute; font-size: 0.55rem; white-space: nowrap; transform: translateX(-50%); }
  .tl-rows { display: flex; flex-direction: column; gap: 2px; }
  .tl-row { display: flex; align-items: center; gap: 0.5rem; }
  .tl-row-label { font-size: 0.58rem; color: var(--empty); width: 96px; flex-shrink: 0; text-align: right; white-space: nowrap; line-height: 1.3; }
  .tl-axis { position: relative; flex: 1; }
  .tl-legend-row { display: flex; flex-wrap: wrap; gap: 0.3rem 1rem; margin-top: 0.6rem; font-size: 0.6rem; color: var(--empty); }
  .tl-legend-item { display: flex; align-items: center; gap: 0.3rem; }
  .tl-legend-dot { width: 10px; height: 6px; border-radius: 1px; flex-shrink: 0; }

  /* Travel calendar */
  .twc-wrap { max-width: 900px; }
  .twc-legend { display: flex; flex-wrap: wrap; gap: 0.4rem 1.4rem; margin-bottom: 2rem; font-size: 0.72rem; }
  .twc-legend-item { display: flex; align-items: center; gap: 0.45rem; }
  .twc-legend-swatch { width: 28px; height: 14px; border-radius: 3px; flex-shrink: 0; }
  .twc-month-label { font-family: 'Fraunces', serif; font-style: italic; font-size: 1.1rem; color: var(--empty); padding: 1.4rem 0 0.5rem; border-bottom: 1px solid var(--rule); margin-bottom: 0.3rem; }
  .twc-row { display: flex; align-items: stretch; border-bottom: 1px solid var(--rule); min-height: 44px; }
  .twc-row:hover { background: rgba(0,0,0,0.02); }
  .twc-row.twc-weekend { background: #f9f6f0; }
  .twc-row.twc-weekend:hover { background: #f2ede3; }
  .twc-date { width: 110px; flex-shrink: 0; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.8rem 0.5rem 0; }
  .twc-daynum { font-family: 'Fraunces', serif; font-size: 1.3rem; font-weight: 600; line-height: 1; color: var(--ink); min-width: 28px; text-align: right; }
  .twc-daynum.twc-weekend-num { color: var(--rule); }
  .twc-dayname { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--empty); }
  .twc-bars { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 3px; padding: 6px 0; }
  .twc-bar-row { display: flex; align-items: center; gap: 6px; height: 14px; }
  .twc-bar-label { width: 72px; flex-shrink: 0; font-size: 0.6rem; color: var(--empty); text-align: right; white-space: nowrap; }
  .twc-bar-track { flex: 1; height: 100%; border-radius: 2px; position: relative; display: flex; align-items: center; }
  .twc-bar-fill { height: 100%; border-radius: 2px; }
  .twc-markers { width: 260px; flex-shrink: 0; display: flex; align-items: center; padding-left: 1rem; gap: 0.4rem; flex-wrap: wrap; }
  .twc-tag { display: inline-block; padding: 0.1rem 0.45rem; border-radius: 2px; font-size: 0.6rem; font-weight: 500; white-space: nowrap; }
  .twc-tag-teach  { background: var(--you-bg);      color: var(--you); }
  .twc-tag-sa     { background: var(--sa-opp-bg);   color: var(--sa-opp); }
  .twc-tag-fw     { background: var(--fieldwork-bg);color: var(--fieldwork); }
  .twc-tag-slovakia { background: var(--slovakia-bg); color: var(--slovakia); }
  .twc-tag-skip   { background: var(--empty-bg);    color: var(--empty); }
  .twc-tag-holiday{ background: var(--holiday-bg);  color: var(--holiday); }
  .twc-tag-exam   { background: #f3e8ff;            color: #7e22ce; }
  .twc-tag-session{ background: #fff7ed;            color: #9a3412; font-style: italic; font-size: 0.58rem; }

  /* ── Travel Calendar tab ── */
  :root {
    --tc-a-short: #fed7aa; --tc-a-short-ink: #c2410c;
    --tc-a-long:  #fdba74; --tc-a-long-ink:  #9a3412;
    --tc-b-short: #fef08a; --tc-b-short-ink: #854d0e;
    --tc-b-long:  #fde047; --tc-b-long-ink:  #713f12;
    --tc-c-short: #bbf7d0; --tc-c-short-ink: #166534;
    --tc-c-long:  #86efac; --tc-c-long-ink:  #14532d;
    --tc-weekend: #f0ede6;
  }
  .tc-legend { display: flex; flex-wrap: wrap; gap: 0.5rem 1.6rem; margin-bottom: 2rem; font-size: 0.68rem; }
  .tc-legend-group { display: flex; flex-direction: column; gap: 0.3rem; }
  .tc-legend-group-label { font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--empty); margin-bottom: 0.1rem; }
  .tc-legend-item { display: flex; align-items: center; gap: 0.4rem; }
  .tc-lswatch { width: 28px; height: 12px; border-radius: 2px; flex-shrink: 0; }
  .tc-lswatch.tc-constraint { border: 1.5px solid #aaa; }
  .tc-cal-wrap { overflow-x: auto; }
  .tc-table { border-collapse: collapse; min-width: 600px; width: 100%; font-size: 0.68rem; }
  .tc-table thead tr.tc-r-labels th { padding: 0.5rem 0.4rem 0.2rem; text-align: center; font-size: 0.65rem; font-weight: 500; letter-spacing: 0.04em; border-bottom: none; white-space: nowrap; }
  .tc-table thead tr.tc-r-dates th { padding: 0.1rem 0.4rem 0.5rem; text-align: center; font-size: 0.58rem; font-style: italic; color: var(--empty); border-bottom: 2px solid var(--ink); white-space: nowrap; }
  .tc-table th.tc-col-date { text-align: left; }
  .tc-table th.tc-h-a-short { background: var(--tc-a-short); color: var(--tc-a-short-ink); }
  .tc-table th.tc-h-a-long  { background: var(--tc-a-long);  color: var(--tc-a-long-ink);  }
  .tc-table th.tc-h-b-short { background: var(--tc-b-short); color: var(--tc-b-short-ink); }
  .tc-table th.tc-h-b-long  { background: var(--tc-b-long);  color: var(--tc-b-long-ink);  }
  .tc-table th.tc-h-c-short { background: var(--tc-c-short); color: var(--tc-c-short-ink); }
  .tc-table th.tc-h-c-long  { background: var(--tc-c-long);  color: var(--tc-c-long-ink);  }
  .tc-table tbody td { padding: 0.28rem 0.4rem; text-align: center; border-bottom: 1px solid var(--rule); height: 32px; vertical-align: middle; }
  .tc-table tbody td.tc-col-date { text-align: left; white-space: nowrap; padding-left: 0; min-width: 90px; }
  .tc-date-num { font-family: 'Fraunces', serif; font-size: 1rem; font-weight: 600; line-height: 1; display: inline-block; min-width: 22px; text-align: right; margin-right: 4px; }
  .tc-date-day { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--empty); }
  .tc-table tr.tc-weekend td { background: var(--tc-weekend); }
  .tc-table tr.tc-weekend .tc-date-num, .tc-table tr.tc-weekend .tc-date-day { color: #bbb; }
  .tc-table tr.tc-month-sep td { background: var(--ink) !important; color: white; font-family: 'Fraunces', serif; font-style: italic; font-size: 0.9rem; text-align: left; padding: 0.5rem 0.5rem; border-bottom: none; }
  .tc-table td.tc-away-a-short { background: var(--tc-a-short) !important; color: var(--tc-a-short-ink); font-size: 0.9rem; }
  .tc-table td.tc-away-a-long  { background: var(--tc-a-long)  !important; color: var(--tc-a-long-ink);  font-size: 0.9rem; }
  .tc-table td.tc-away-b-short { background: var(--tc-b-short) !important; color: var(--tc-b-short-ink); font-size: 0.9rem; }
  .tc-table td.tc-away-b-long  { background: var(--tc-b-long)  !important; color: var(--tc-b-long-ink);  font-size: 0.9rem; }
  .tc-table td.tc-away-c-short { background: var(--tc-c-short) !important; color: var(--tc-c-short-ink); font-size: 0.9rem; }
  .tc-table td.tc-away-c-long  { background: var(--tc-c-long)  !important; color: var(--tc-c-long-ink);  font-size: 0.9rem; }
  .tc-table tr.tc-constraint-row td.tc-col-date { background: #f3f0ff; }
  .tc-table tr.tc-constraint-row td.tc-constraint-label { background: #f3f0ff; }
  .tc-table tr.tc-constraint-row .tc-date-num, .tc-table tr.tc-constraint-row .tc-date-day { color: #6d28d9; }
  .tc-table tr.tc-constraint-row td.tc-col-date { font-weight: 500; }
  .tc-table tr.tc-holiday-row .tc-date-num, .tc-table tr.tc-holiday-row .tc-date-day { color: #b91c1c; }
  .tc-constraint-label { font-size: 0.62rem; font-style: italic; text-align: left; padding-left: 0.3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
  .tc-table tr.tc-constraint-row .tc-constraint-label { color: #6d28d9; background: #f3f0ff; }
  .tc-table tr.tc-holiday-row .tc-constraint-label { color: #b91c1c; }
  .tw-cell { width: 22px !important; padding: 0 3px !important; vertical-align: middle !important; }
  .tw-pip  { width: 12px; height: 4px; border-radius: 1px; margin: 1px auto; }
  .tw-gap  { width: 12px; height: 4px; margin: 1px auto; }
  .cp-legend { display: flex; flex-wrap: wrap; gap: 0.4rem 1.1rem; margin-bottom: 1.5rem; font-size: 0.68rem; }
  .cp-table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
  .cp-table th { text-align: left; padding: 0.45rem 0.65rem; border-bottom: 2px solid var(--ink); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; background: var(--bg); position: sticky; top: 0; white-space: nowrap; }
  .cp-table td { padding: 0.4rem 0.65rem; border-bottom: 1px solid var(--rule); vertical-align: top; font-size: 0.7rem; }
  .cp-month td { font-family: 'Fraunces', serif; font-style: italic; font-size: 0.88rem; padding-top: 1.2rem; padding-bottom: 0.35rem; color: var(--empty); border-bottom: 1px solid var(--rule); }
  .cp-you      td { background: #f0faf2 !important; }
  .cp-you      td:first-child { border-left: 3px solid var(--you); }
  .cp-sa-opp   td { background: #eaf9f5 !important; }
  .cp-sa-opp   td:first-child { border-left: 3px solid var(--sa-opp); }
  .cp-sa       td { background: #eff6ff !important; }
  .cp-sa       td:first-child { border-left: 3px solid var(--sa); }
  .cp-fw       td { background: var(--fieldwork-bg) !important; }
  .cp-fw       td:first-child { border-left: 3px solid var(--fieldwork); }
  .cp-slovakia td { background: var(--slovakia-bg) !important; }
  .cp-slovakia td:first-child { border-left: 3px solid var(--slovakia); }
  .cp-skip     td { background: var(--empty-bg) !important; opacity: 0.5; }
  .cp-content-block { margin-bottom: 0.4rem; line-height: 1.5; }
  .cp-activity { display: inline-block; background: #fce7f3; color: #9d174d; padding: 0.1rem 0.4rem; border-radius: 2px; font-size: 0.6rem; margin-right: 0.3rem; white-space: nowrap; }
  .cp-reading  { display: inline-block; background: #fef9c3; color: #ca8a04; padding: 0.1rem 0.4rem; border-radius: 2px; font-size: 0.6rem; margin-right: 0.3rem; white-space: nowrap; }
  .cp-mins     { color: var(--empty); font-size: 0.6rem; font-style: italic; white-space: nowrap; }
  .cp-sa-note  { font-size: 0.62rem; color: var(--sa); font-style: italic; }
  .cp-note     { font-size: 0.62rem; color: var(--empty); font-style: italic; }
</style>
</head>
<body>

<header>
  <h1>Module Schedule <span>Spring 2026</span></h1>
  <p class="subtitle">Wed &amp; Thu · 10:15–11:45 &amp; 12:15–13:45 · Fieldwork 1–5 June</p>
</header>

<div class="page-tabs">
  <button class="page-tab active" onclick="showPage('schedule')">Teaching Schedule</button>
  <button class="page-tab" onclick="showPage('content')">Content Plan</button>
  <button class="page-tab" onclick="showPage('workshop')">Workshop Availability</button>
  <button class="page-tab" onclick="showPage('windows')">Travel Windows</button>
  <button class="page-tab" onclick="showPage('trcal')">Travel Calendar</button>
</div>

<!-- ══ TEACHING SCHEDULE ══ -->
<div class="page-section visible" id="page-schedule">

  <div class="legend">
    <div class="legend-item"><div class="ldot" style="background:var(--you-bg);border:1.5px solid var(--you)"></div>You</div>
    <div class="legend-item"><div class="ldot" style="background:var(--sa-opp-bg);border:1.5px solid var(--sa-opp)"></div>SA covers — you away</div>
    <div class="legend-item"><div class="ldot" style="background:var(--sa-bg);border:1.5px solid var(--sa)"></div>SA covers — planned handover</div>
