    t.classList.toggle('active', ['A','B','C','X','W'][i] === planId);
  });
  renderTimeline('tl-schedule', planId);
  const plan = getPlans()[planId];
  const tbody = document.getElementById('sb');
  tbody.innerHTML = '';
  let hrs=0, sws=0, dayN=0, youD=0, saD=0, saOppD=0;

  BASE.forEach(r => {
    if (r[0]==='_MONTH') { addRow(tbody,'r-month',`<td colspan="8">${r[1]}</td>`); return; }
    const [date,day,baseType,baseNote] = r;
    const ov = plan[date];
    let type = baseType, note = baseNote;
    if (ov && !baseType)    { type=ov[0]; note=ov[1]||baseNote; }
    else if (ov && baseType){ 
      // Allow plan to promote a post/skip row to a teaching day
      if (['post','skip'].includes(baseType) && ['you','sa','sa_opp'].includes(ov[0])) {
        type=ov[0];
      }
      note=ov[1]||baseNote;
    }

    const isTeach = ['you','sa','sa_opp'].includes(type);
    const rowCls = type==='sa_opp' ? ' opp' : (type==='sa' ? ' sa-hand' : '');

    if (type==='fieldwork') {
      hrs+=4; sws+=4;
      addRow(tbody,'r-single r-fw',`${td(`<strong>${date}</strong>`)}${td(day,'sid')}${td(pill(type))}${twCell(date)}${td('—','sid')}${td('All day','tlbl')}${td(note||'','nt')}${td(hrs+' hrs','tc')}${td(sws+' SWS','tc')}`);
