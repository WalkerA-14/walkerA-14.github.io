  d(2026,4,22),d(2026,4,23),d(2026,5,5),d(2026,5,14),
  d(2026,6,24),d(2026,6,25),d(2026,7,1),d(2026,7,2),
];

function dtEq(a,b) {
  return a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate();
}
function inList(dt, list) { return list.some(x => dtEq(dt,x)); }
function inWindow(dt, win) { return win && dt>=win.start && dt<=win.end; }

function yourStatus(dt, planId) {
  if (inList(dt, FIELDWORK_DATES)) return { busy:true, reason:'Fieldwork week' };
  if (inList(dt, SLOVAKIA_DATES))  return { busy:true, reason:'Slovakia fieldtrip (workshop)' };
  if (inList(dt, SKIP_DATES))      return { busy:true, reason: dtEq(dt, d(2026,5,5)) ? 'German exam' : 'Confirmed skip / holiday' };
  if (planId === 'W') {
    if (ALL_TRAVEL_WINDOWS.some(w => dt>=w.start && dt<=w.end))
      return { busy:true, reason:'Potential travel (any option)' };
  } else if (planId === 'W-short') {
    if (ALL_TRAVEL_WINDOWS_SHORT.some(w => dt>=w.start && dt<=w.end))
      return { busy:true, reason:'Potential travel (short, any option)' };
  } else {
    const win = TRAVEL_WINDOWS[planId];
    if (win && dt>=win.start && dt<=win.end) return { busy:true, reason:'Away — travel' };
  }
  if (inList(dt, TEACHING_DATES))  return { busy:true, reason:'Teaching day' };
  return { busy:false, reason:'' };
}

function colleagueAvail(dt) {
  return COLLEAGUE_WINDOWS.some(w => dt>=w.start && dt<=w.end) ||
         inList(dt, SLOVAKIA_DATES);
}

function isSlovakiaDay(dt) { return inList(dt, SLOVAKIA_DATES); }

function showWorkshop(planId) {
  const WS_PLANS = ['A-short','A-long','B-short','B-long','C-short','C-long','X','W-short','W'];
  document.querySelectorAll('#ws-plan-tabs .tab').forEach((t,i) => {
    t.classList.toggle('active', WS_PLANS[i] === planId);
  });
  renderTimeline('tl-workshop', planId);
  const tbody = document.getElementById('ws-body');
  tbody.innerHTML='';

  let cur = d(2026,4,8);
  const end = d(2026,7,16);
  let bothCount=0, lastMonth=-1;

  while (cur<=end) {
    if (cur.getMonth()!==lastMonth) {
      lastMonth=cur.getMonth();
      const tr=document.createElement('tr');
      tr.className='ws-month';
      tr.innerHTML=`<td colspan="6">${MN[cur.getMonth()]} ${cur.getFullYear()}</td>`;
      tbody.appendChild(tr);
    }

    const colAvail = colleagueAvail(cur);
    const ys = yourStatus(cur, planId);
    const youFree = !ys.busy;
    const isSlovakia = isSlovakiaDay(cur);
    if (youFree && colAvail) bothCount++;

    const rowCls = isSlovakia                  ? 'ws-both'
                 : youFree && colAvail         ? 'ws-both'
                 : !youFree && colAvail        ? 'ws-col-only'
                 : youFree && !colAvail        ? 'ws-you-only'
                 : 'ws-neither';

    const wPill = isSlovakia                   ? `<span class="pill p-slovakia">Slovakia fieldtrip</span>`
                : youFree && colAvail          ? '<span class="pill p-both">Both available</span>'
                : !youFree && colAvail         ? '<span class="pill p-col-only">Colleague only</span>'
                : youFree && !colAvail         ? '<span class="pill p-you-only">You only</span>'
                : '<span class="pill p-neither">Neither</span>';

    const youLbl = isSlovakia ? '★ Slovakia trip' : youFree ? '✓ Free' : `✗ ${ys.reason}`;
    const colLbl = colAvail ? '✓ Available' : '✗ Away';
    const noteLbl = isSlovakia ? 'Workshop fieldtrip — colleague + SA possibly present'
                  : youFree && colAvail ? 'Workshop opportunity' : '';

    const tr=document.createElement('tr');
    tr.className=rowCls;
    tr.innerHTML=`
      <td><strong>${cur.getDate()} ${MN[cur.getMonth()]}</strong></td>
      <td style="color:var(--empty);font-size:0.62rem">${DN[cur.getDay()]}</td>
      <td>${wPill}</td>
      ${twCellFromDate(cur)}
      <td style="font-size:0.62rem;color:${youFree?'var(--you)':'var(--empty)'}">${youLbl}</td>
      <td style="font-size:0.62rem;color:${colAvail?'#5c2a7a':'var(--empty)'}">${colLbl}</td>
      <td style="font-size:0.62rem;color:var(--empty);font-style:italic">${noteLbl}</td>
    `;
    tbody.appendChild(tr);
    cur=addDays(cur,1);
  }

  const planLabel = {
    'A-short':'Option A short (10–17 Apr)', 'A-long':'Option A long (10–19 Apr)',
    'B-short':'Option B short (24 Apr–1 May)', 'B-long':'Option B long (24 Apr–3 May)',
    'C-short':'Option C short (8–15 May)', 'C-long':'Option C long (8–17 May)',
    'X':'no travel',
    'W-short':'worst case short (all short windows combined)',
    'W':'worst case long (all long windows combined)'
  }[planId] || planId;
  document.getElementById('ws-summary').textContent =
    `${bothCount} days where both of you are free — ${planLabel}.`;
}

